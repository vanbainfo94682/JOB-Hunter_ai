# ───────────────────────────────────────────────────────────────
# Supabase Configuration
# ───────────────────────────────────────────────────────────────
# Create a project at https://supabase.com → Project Settings → API
# Copy the values below:

SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...    # anon/public key
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9... # service_role key (server-side)

# ───────────────────────────────────────────────────────────────
# App Configuration
# ───────────────────────────────────────────────────────────────
PORT=5000

# ───────────────────────────────────────────────────────────────
# OpenRouter (default key used when user has not set their own)
# ───────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...

# ───────────────────────────────────────────────────────────────
# Razorpay Payments (optional — leave empty if not yet integrated)
# ───────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=...
